generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  fullName     String
  dob          String?
  gender       String?
  mobile       String        @unique
  password     String
  email        String?
  aadhaar      String?       @unique
  pan          String?
  category     String?
  education    String?
  address      String?
  state        String?
  district     String?
  bankAccount  String?
  ifsc         String?
  rationCard   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Application {
  refNo         String   @id
  userId        String?
  stateId       String?
  schemeId      String?
  schemeName    String?
  status        String   @default("Submitted")
  statusHistory Json     @default("[]")
  formData      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id])
}

model CustomScheme {
  id          String   @id @default(cuid())
  stateId     String
  title       String
  description String?
  benefit     String?
  eligibility String?
  documents   Json     @default("[]")
  deadline    String?
  category    String?
  formFields  Json     @default("[]")
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stateId])
}

model CustomExam {
  id          String   @id @default(cuid())
  stateId     String
  title       String
  description String?
  date        String?
  lastDate    String?
  fee         String?
  eligibility String?
  posts       Int?
  category    String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stateId])
}

model CustomCompany {
  id          String   @id @default(cuid())
  stateId     String
  name        String
  type        String?
  industry    String?
  location    String?
  description String?
  website     String?
  jobs        Json     @default("[]")
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stateId])
}

model DistrictRole {
  id        String   @id @default(cuid())
  stateId   String
  district  String
  role      String
  name      String
  mobile    String?
  email     String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stateId])
  @@index([district])
}

model CustomScholarship {
  id          String   @id @default(cuid())
  stateId     String
  title       String
  description String?
  amount      String?
  eligibility String?
  lastDate    String?
  category    String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stateId])
}

model CustomTender {
  id          String   @id @default(cuid())
  stateId     String
  title       String
  description String?
  value       String?
  lastDate    String?
  category    String?
  department  String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stateId])
}

model State {
  id      String  @id
  name    String
  capital String?
  region  String?
  color   String?
  emoji   String?
  schemes Int     @default(0)
  type    String  @default("state")
}

model District {
  id      String @id @default(cuid())
  stateId String
  name    String

  @@index([stateId])
}

model GovSector {
  name  String  @id
  icon  String?
  color String?
}

model GovEmployee {
  id          String  @id
  stateId     String
  name        String
  designation String?
  department  String?
  sector      String?
  salary      Int?
  joiningDate String?
  pan         String? @unique
  district    String?
  grade       String?
  serviceType String?

  @@index([stateId])
}

model PrivateOrg {
  id            String  @id
  name          String
  shortName     String?
  gst           String?
  sector        String?
  stateId       String?
  stateName     String?
  district      String?
  city          String?
  employees     Int?
  founded       Int?
  icon          String?
  color         String?
  adminPassword String?
  description   String?

  @@index([stateId])
}

model Scheme {
  id          String   @id
  stateId     String?
  name        String
  nameHindi   String?
  ministry    String?
  category    String?
  benefit     String?
  eligibility String?
  icon        String?
  description String?
  documents   Json     @default("[]")
  formFields  Json     @default("[]")
  createdAt   DateTime @default(now())
  badgeColor  String?
  color       String?
  extra       Json?
  hasPanLogic Boolean  @default(false)
  nameLocal   String?
  scope       String   @default("state")

  @@index([scope])
  @@index([stateId])
}

model Exam {
  id                  String   @id
  stateId             String?
  name                String
  shortName           String?
  conductedBy         String?
  category            String?
  posts               String?
  applicationFee      String?
  eligibility         String?
  nextExam            String?
  applicationDeadline String?
  icon                String?
  status              String?
  description         String?
  formFields          Json     @default("[]")
  createdAt           DateTime @default(now())
  badgeColor          String?
  color               String?
  scope               String   @default("state")

  @@index([scope])
  @@index([stateId])
}

model Scholarship {
  id          String   @id
  stateId     String?
  name        String
  nameHindi   String?
  ministry    String?
  category    String?
  subcategory String?
  benefit     String?
  eligibility String?
  icon        String?
  description String?
  documents   Json     @default("[]")
  formFields  Json     @default("[]")
  createdAt   DateTime @default(now())
  badgeColor  String?
  color       String?
  nameLocal   String?
  scope       String   @default("state")

  @@index([scope])
  @@index([stateId])
}

model Tender {
  id              String   @id
  stateId         String
  name            String
  shortName       String?
  department      String?
  category        String?
  subcategory     String?
  estimatedValue  String?
  bidDeadline     String?
  workDescription String?
  eligibility     String?
  icon            String?
  status          String?
  tenderNo        String?
  documents       Json     @default("[]")
  formFields      Json     @default("[]")
  createdAt       DateTime @default(now())

  @@index([stateId])
}

model Beneficiary {
  pan       String   @id
  name      String
  mobile    String?
  schemes   Json     @default("[]")
  status    String   @default("active")
  employer  Json?
  appliedOn String?
  updatedAt DateTime @updatedAt
}

model CompanyEmployee {
  uid     String  @id
  orgId   String
  pan     String
  name    String?
  mobile  String?
  email   String?
  addedOn String?

  @@index([orgId])
}

model GovAdmin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  stateId   String
  stateName String
  emoji     String?
  level     String   @default("state")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
